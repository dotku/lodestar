# --- Runtime env (production needs these on Vercel) ---

# Vercel AI Gateway API key — powers the interactive demo widget.
# Get one at https://vercel.com/<team>/~/ai/api-keys
# Demo route uses provider/model strings (e.g. "openai/gpt-4o-mini") via the gateway.
AI_GATEWAY_API_KEY=

# Override the demo model (optional). Default: openai/gpt-4o-mini
LODESTAR_DEMO_MODEL=openai/gpt-4o-mini

# Resend transactional email API key — powers the contact form.
# Get one at https://resend.com/api-keys
# Set on Vercel under: Project → Settings → Environment Variables
RESEND_API_KEY=

# Vercel Blob (auto-provisioned by the Blob integration on Vercel).
# Locally, pull via `vercel env pull` after linking.
BLOB_READ_WRITE_TOKEN=

# --- Build-time / generation scripts (NOT needed at runtime) ---

# Seedance video API key is NOT needed for Lodestar runtime.
# Promo videos are pre-generated and uploaded to Vercel Blob.
# To regenerate videos, the key lives in ~/dev/x-post-scheduler/.env.local
# and scripts/generate-video.mjs reads it from there if you symlink/copy.
# Do NOT add SEEDANCE_API_KEY here.
