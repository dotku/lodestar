# Vercel AI Gateway API key — required for the interactive demo widget.
# Get one at https://vercel.com/<team>/~/ai/api-keys
# The demo route uses provider/model strings (e.g. "openai/gpt-4o-mini") routed through the gateway.
AI_GATEWAY_API_KEY=

# Override the default model used by the demo (optional).
# Default: openai/gpt-4o-mini
LODESTAR_DEMO_MODEL=openai/gpt-4o-mini
